{
    "apt": {
        "vital_packages": [
            "bzip2",
            "curl",
            "g++",
            "gcc",
            "gnupg2",
            "lsb-release",
            "make",
            "jq",
            "software-properties-common",
            "tar",
            "unzip",
            "wget"
        ],
        "common_packages": [
            "autoconf",
            "automake",
            "dbus",
            "dnsutils",
            "dpkg",
            "dpkg-dev",
            "fakeroot",
            "fonts-noto-color-emoji",
            "gnupg2",
            "iproute2",
            "iputils-ping",
            "libyaml-dev",
            "libtool",
            "libssl-dev",
            "libsqlite3-dev",
            "locales",
            "mercurial",
            "openssh-client",
            "p7zip-rar",
            "pkg-config",
            "python-is-python3",
            "rpm",
            "texinfo",
            "tk",
            "tree",
            "tzdata",
            "upx",
            "xvfb",
            "xz-utils",
            "zsync"
        ],
        "cmd_packages": [
            "acl",
            "aria2",
            "binutils",
            "bison",
            "brotli",
            "libnss3-tools",
            "coreutils",
            "file",
            "findutils",
            "flex",
            "ftp",
            "haveged",
            "lz4",
            "m4",
            "mediainfo",
            "netcat-openbsd",
            "net-tools",
            "p7zip-full",
            "parallel",
            "patchelf",
            "pigz",
            "pollinate",
            "rsync",
            "shellcheck",
            "sqlite3",
            "ssh",
            "sshpass",
            "sudo",
            "swig",
            "telnet",
            "time",
            "zip"
        ]
    },
    "docker": {
        "components": [
            {
                "package": "docker-ce-cli",
                "version": "latest"
            }
        ],
        "plugins": [
            {
                "plugin": "buildx",
                "version": "latest",
                "asset": "linux-amd64"
            },
            {
                "plugin": "compose",
                "version": "latest",
                "asset": "linux-x86_64"
            }
        ]
    },
    "node": {
        "default": "20"
    },
    "node_modules": [
        { "name": "typescript", "command": "tsc" },
        { "name": "yarn", "command": "yarn" },
        { "name": "n", "command": "n" }
    ],
    "pipx": [
        { "package": "yamllint", "cmd": "yamllint" }
    ]
}
